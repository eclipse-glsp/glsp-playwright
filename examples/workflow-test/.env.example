# ── Repository Configuration ─────────────────────────────────────────────────
# Directory where the GLSP server repositories are stored.
GLSP_REPO_DIR=.repositories 

# ── General (shared by all integrations that use the GLSP server) ────────────
GLSP_SERVER_PORT=8081
GLSP_SERVER_DEBUG=true
GLSP_WEBSOCKET_PATH=workflow
GLSP_SERVER_TYPE=node

# ── Port Configuration (optional, defaults shown) ────────────────────────────
# STANDALONE_PORT=8082
# STANDALONE_BROWSER_PORT=8083
# THEIA_PORT=3000

# ── VS Code (optional, defaults to false) ────────────────────────────────────
# USE_WEB_EXTENSION=true
