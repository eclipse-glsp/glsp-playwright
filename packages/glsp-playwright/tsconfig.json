{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "baseUrl": ".",
    // This package uses reflect-metadata (DI decorators); declared as a dependency.
    "types": ["node", "reflect-metadata"],
    "paths": {
      "~/": ["src"],
      "~/*": ["src/*"]
    }
  },
  "include": ["src", "scripts"]
}
